{
  "functions": {
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/search.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat.js"
    },
    {
      "source": "/api/search",
      "destination": "/api/search.js"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}